{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build lab4",
      "type": "shell",
      "command": "gcc",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "main.c",
        "avl.c",
        "-o",
        "${workspaceFolder}\\main.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": "build",
      "detail": "Build Lab4 from main.c and avl.c."
    },
    {
      "label": "C/C++: gcc.exe 生成活动文件",
      "type": "shell",
      "command": "gcc",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "main.c",
        "avl.c",
        "-o",
        "${workspaceFolder}\\main.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Build Lab4 from main.c and avl.c. This overrides VS Code's single-file build task."
    }
  ]
}
